{
"manifest_version": 3,
"name": "Slime Tabs Lord",
"version": "4.0.1",
"description": "Close tabs with style! An adorable animated slime mascot helps you manage browser tabs with fun animations and customizable colors.",
"author": "pepeyc7526",
"homepage_url": "https://github.com/pepeyc7526/slime-tabs-lord",
"permissions": ["tabs", "sessions", "storage", "theme", "bookmarks"],
"background": {
"scripts": ["background.js"]
},
"action": {
"default_popup": "popup.html",
"default_title": "Slime Tabs Lord"
},
"options_ui": {
"page": "options.html",
"open_in_tab": true
},
"icons": {
"48": "icons/icon-logo-48.png",
"96": "icons/icon-logo-96.png",
"128": "icons/icon-logo-128.png"
},
"browser_specific_settings": {
"gecko": {
"id": "slime-tabs-lord-pub@pepeyc7526.github.io",
"strict_min_version": "142.0",
"data_collection_permissions": {
"collects_data": false,
"required": ["none"]
}
}
}
}
